{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ad-generator",
  "main": "worker.mjs",
  "compatibility_date": "2026-05-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "compatibility_flags": ["nodejs_compat"]
}
